# ─────────────────────────────────────────────
# 오즈랩페이 환경변수 템플릿
# - 실제 값은 .env.local 에 넣을 것 (이 파일은 커밋되지만 .env.local 은 gitignore)
# - Vercel 배포 시 프로젝트 Settings → Environment Variables 에도 동일하게 등록
# ─────────────────────────────────────────────

# Supabase — 프로젝트 > Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxx

# (선택) 서버 전용 — service_role 키. 서버 라우트에서만 사용
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxx

# (선택) GTM / GA4
#   - 미설정 시 lib/seo.ts 의 fallback 값(GTM-N3HSNZPJ) 사용
#   - 운영 컨테이너 바꾸려면 이 값 override (Vercel env 동기화 필수)
NEXT_PUBLIC_GTM_ID=GTM-N3HSNZPJ

# (선택) generate_lead 1차 추정 net 마진 (KRW)
#   - 폼 제출 시점에 GA4 로 보내는 추정값. 실제 net 은 매출 입력 시 서버에서 MP 로 보정 (A-3)
#   - 운영하면서 평균값 조정 (현재 fallback 30000)
# NEXT_PUBLIC_LEAD_DEFAULT_VALUE=30000

# (A-3 단계) GA4 Measurement Protocol — 매출 입력 시 서버에서 동적 net 마진 전송용
#   - GA4 프로퍼티 만들고 측정 ID + API secret 발급한 후 입력
#   - 미설정 시 매출 보정 코드는 no-op (안전)
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_API_SECRET=XXXXXXXXXXXXXXXXXXXX

# Meta Conversions API (CAPI) — 픽셀과 짝꿍, 신호 손실 보정
#   - 폼 제출 시: 서버에서 Lead 이벤트 발사 (브라우저 픽셀 Lead 와 event_id 로 dedupe)
#   - 매출 입력 시: 서버에서 Purchase 이벤트 발사 (value = net 마진)
#   - 비즈매니저 → 이벤트 관리자 → 픽셀 → 설정 → Conversions API → 액세스 토큰 생성
#   - 둘 다 없으면 sendMeta* 헬퍼는 no-op (안전)
# META_PIXEL_ID=000000000000000
# META_CAPI_TOKEN=EAAxxxxxxxxx
# META_CAPI_TEST_CODE=TEST12345   # (선택) 검증 단계만 사용, prod 데이터 안 쌓임

# CRMPro 외부 DB 전송 — 폼 저장 성공 후 CRMPro /api/db/submit 으로 서버 전송
#   - API 키는 서버 전용. 절대 NEXT_PUBLIC_ prefix 로 만들지 말 것
#   - group_no 158 = 오즈랩페이 CRMPro DB 그룹
#   - 미설정 시 CRMPro 전송은 no-op 이며, 오즈랩 로컬 DB 저장은 계속 동작
# CRM_PRO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CRM_PRO_GROUP_NO=158
# CRM_PRO_BASE_URL=https://crmpro.kr/api
